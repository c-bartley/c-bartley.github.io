---
layout: null
---
{
  "version": "https://jsonfeed.org/version/1.1",
  "title": {{ site.title | jsonify }},
  "home_page_url": {{ site.url | append: site.baseurl | jsonify }},
  "feed_url": {{ site.url | append: site.baseurl | append: "/blog.json" | jsonify }},
  "description": {{ site.description | jsonify }},
  "icon": {{ site.avatar | absolute_url | jsonify }},
  "author": {
    "name": {{ site.author | jsonify }},
    "url": {{ site.url | append: site.baseurl | jsonify }}
  },
  "items": [
    {% assign crossposts = site.posts | where_exp: "post", "post.crosspost != false" -%}
    {%- for post in crossposts -%}
    {
      "id": {{ post.url | absolute_url | jsonify }},
      "url": {{ post.url | absolute_url | jsonify }},
      "title": {{ post.title | jsonify }},
      "content_html": {{ post.content | jsonify }},
      "summary": {{ post.excerpt | strip_html | jsonify }},
      "date_published": {{ post.date | date_to_xmlschema | jsonify }}
      {%- if post.last_modified_at %},
      "date_modified": {{ post.last_modified_at | date_to_xmlschema | jsonify }}
      {%- endif -%}
      {%- if post.tags.size > 0 %},
      "tags": {{ post.tags | jsonify }}
      {%- endif %}
    }{%- unless forloop.last %},{% endunless %}
    {%- endfor %}
  ]
}
